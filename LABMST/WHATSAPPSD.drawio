        <mxCell id="cHY7BrONow4dXKlj4d97-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=14;" value="Design a Whatsapp System&amp;nbsp; with proper following requirements&lt;div&gt;1. User Service&lt;/div&gt;&lt;div&gt;2. Chat Service&lt;/div&gt;&lt;div&gt;3. Group Service&lt;/div&gt;" vertex="1">
