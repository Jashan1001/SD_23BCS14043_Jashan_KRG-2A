        <mxCell id="cHY7BrONow4dXKlj4d97-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;Daily Active Users- 1.5 Million&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Type of Connection&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Last Seen Functioanlity&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Implement CDC Pipeline&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="250" x="450" y="60" as="geometry" />
        </mxCell>
        <mxCell id="cHY7BrONow4dXKlj4d97-8" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 19px;&quot;&gt;FUNCTIONAL REQUIREMENTS:&lt;/font&gt;&lt;div&gt;&lt;span style=&quot;font-size: 19px;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;div&gt;1. USER MUST BE ABLE TO CHAT WITH ANOTHER USER&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;2. USER CAN SEARCH ANY MESSAGE OR CONTACT.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;3. USER CAN BE PART OF ANY GROUP.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;4. USER CAN SEE THE LAST SEEN OF ANOTHER USER.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;5. USER MUST GET TO KNOW WHTHER THE OTHER USER IS ACTIVE OR NOT&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="180" width="570" x="40" y="160" as="geometry" />
        </mxCell>
        <mxCell id="cHY7BrONow4dXKlj4d97-9" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 19px;&quot;&gt;NON-FUNCTIONAL REQUIREMENTS:&lt;/font&gt;&lt;div&gt;&lt;span style=&quot;font-size: 19px;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;div&gt;1.MESSAGE SHOULD BE DELIVERED VERY FAST. &amp;lt;1-2 SEC&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;2. MESSAGES MUST BE SECURED (END TO END ENCRYPTION)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;3. LATENCY MUST BE VERY LOW. &amp;lt;500MS&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;4.HIGH AVAILABILITY&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;5. SCALABILITY&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
